// 식단 사진은 Firestore 규칙과 동소스로 — 달력 공유 받은 친구만 원본 Storage 를 읽을 수 있음.
// 건강 사진은 /users/{uid}/media/health/ 아래만 두고 소유자만 read/write (친구는 Firestore 에서부터 차단).
//
// 교차 규칙 적용 시 콘솔에서 Storage 서비스 계정의 Firestore 읽기 연동 허용이 필요할 수 있습니다.
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    /** Firestore calendarShareAllows 와 동일 — scope 없음·calendar 미표기 허용, calendar 명시 false 만 차단 */
    function viewerShareCalendarOk(ownerUid) {
      let shareId = ownerUid + '_' + request.auth.uid;
      let p = /databases/(default)/documents/shares/$(shareId);
      let d = firestore.get(p).data;
      return signedIn()
        && firestore.exists(p)
        && d.ownerUid == ownerUid
        && d.viewerUid == request.auth.uid
        && (
          !('scope' in d)
          || !(d.scope is map)
          || !('calendar' in d.scope)
          || !(d.scope.calendar is bool && d.scope.calendar == false)
        );
    }

    match /users/{ownerUid}/media/meals/{path=**} {
      allow read: if signedIn() && (
        request.auth.uid == ownerUid ||
        viewerShareCalendarOk(ownerUid)
      );
      allow write: if signedIn() && request.auth.uid == ownerUid;
    }

    /**
     * 일부 환경·콘솔에서는 users/ 없이 {firebaseUid}/media/meals/ 만 보입니다.
     * users/ 규칙과 중복되지 않게 첫 세그먼트가 "users" 가 아닐 때만 허용합니다.
     */
    match /{ownerUid}/media/meals/{path=**} {
      allow read: if signedIn()
        && ownerUid != "users"
        && ownerUid.size() >= 15
        && (
          request.auth.uid == ownerUid ||
          viewerShareCalendarOk(ownerUid)
        );
      allow write: if signedIn()
        && ownerUid != "users"
        && ownerUid.size() >= 15
        && request.auth.uid == ownerUid;
    }

    match /users/{ownerUid}/media/health/{path=**} {
      allow read, write: if signedIn() && request.auth.uid == ownerUid;
    }

    match /{ownerUid}/media/health/{path=**} {
      allow read, write: if signedIn()
        && ownerUid != "users"
        && ownerUid.size() >= 15
        && request.auth.uid == ownerUid;
    }

    match /{anyPath=**} {
      allow read, write: if false;
    }
  }
}
