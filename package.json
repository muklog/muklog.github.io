{
  "name": "muklog",
  "private": true,
  "version": "0.1.14",
  "type": "module",
  "description": "달력·식단·AI 분석과 친구 피드 — 한 기기에서는 내 프로필로 기록하는 먹로그 웹앱",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc -b --noEmit",
    "test:gemini": "node scripts/test-gemini.mjs",
    "test:auth": "vite --host --open /auth-test.html",
    "firebase:login": "npx --yes firebase-tools login",
    "firebase:login:remote": "npx --yes firebase-tools login --no-localhost",
    "deploy:firestore-rules": "npx --yes firebase-tools deploy --only firestore:rules",
    "deploy:firestore": "npx --yes firebase-tools deploy --only firestore",
    "deploy:storage-rules": "npx --yes firebase-tools deploy --only storage",
    "deploy:storage-cors": "gsutil cors set storage-cors.json gs://healthhealth-23fa9.firebasestorage.app",
    "deploy:storage-cors:appspot": "gsutil cors set storage-cors.json gs://healthhealth-23fa9.appspot.com",
    "gen:icons": "node scripts/gen-pwa-icons.mjs",
    "preview:launcher-icon": "node scripts/preview-android-launcher-icon.mjs",
    "gen:play-graphic": "node scripts/gen-play-feature-graphic.mjs",
    "android:bubblewrap": "npx --yes @bubblewrap/cli@latest",
    "android:patch-splash": "node scripts/patch-twa-splash-rounded.mjs",
    "android:build-aabs:internal-closed": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-twa-internal-closed-aabs.ps1",
    "android:build-twa": "powershell -NoProfile -ExecutionPolicy Bypass -File ./twa-android/setup-and-build.ps1",
    "assetlinks:sync": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sync-assetlinks-from-keystore.ps1"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "date-fns": "^4.1.0",
    "dexie": "^4.0.10",
    "dexie-react-hooks": "^1.1.7",
    "firebase": "^12.12.1",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.4.49",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^0.21.0"
  }
}
