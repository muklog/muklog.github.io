# 로컬 개발: 이 파일을 복사해 .env.local 로 저장한 뒤 값을 채우세요.
# Firebase Console → 프로젝트 설정 → 일반 → 내 앱 → 웹 앱 구성

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
# 선택 — initializeApp 호환용. Storage API 는 사용하지 않습니다.
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# GitHub Pages 배포 시: 저장소 Settings → Secrets and variables → Actions 에 동일 이름으로 등록
# (muklog.github.io 저장소로 옮겼다면 그 저장소에도 같은 Secrets 를 다시 넣어야 합니다.)
# Firebase Authentication → Authorized domains 에 호스트(muklog.github.io) 추가 필수
