rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function me() { return request.auth.uid; }
    function myEmail() { return request.auth.token.email; }

    // ----- 단방향 share -----
    // shares/{ownerUid}_{viewerUid} : owner 가 viewer 에게 공개하는 범위.
    // 한 방향 = 한 문서. 맞팔이면 두 문서(서로 owner/viewer 뒤집힘)가 존재한다.

    function shareData(ownerUid) {
      return get(/databases/$(database)/documents/shares/$(ownerUid + '_' + me())).data;
    }

    function isViewerWithScope(ownerUid, scope) {
      let s = shareData(ownerUid);
      return s != null
        && s.ownerUid == ownerUid
        && s.viewerUid == me()
        && s.scope[scope] == true;
    }

    /** calendar 가 명시적으로 bool false 일 때만 차단 — 클라이언트 `scope.calendar !== false` 와 동일 */
    function calendarShareAllows(scope) {
      return scope == null
        || !(scope is map)
        || !('calendar' in scope)
        || !(scope.calendar is bool && scope.calendar == false);
    }

    /** owner 가 viewer 에게 달력 공유 허용(shared 문서 존재 + calendar 가 명시적으로 false 가 아님) */
    function calendarShareToward(ownerUid, viewerUid) {
      let p = /databases/$(database)/documents/shares/$(ownerUid + '_' + viewerUid);
      return exists(p) && (
        !('scope' in get(p).data)
        || calendarShareAllows(get(p).data.scope)
      );
    }
    /** 한쪽이라도 위 조건이면 DM·알림(같은 경로) 허용 — 레거시 scope 누락 문서와 맞춤 */
    function dmCalendarConnected(a, b) {
      return calendarShareToward(a, b) || calendarShareToward(b, a);
    }

    // ----- 본인 UID 하위 — 소유자는 전부, viewer 는 허용 범위만 read -----
    match /users/{userId}/meals/{docId} {
      allow read:  if signedIn() && (me() == userId || isViewerWithScope(userId, 'calendar'));
      allow write: if signedIn() && me() == userId;
    }
    match /users/{userId}/health/{docId} {
      // 건강 기록은 민감 정보라 친구와 공유하지 않는다 — 오직 본인만 read/write.
      // (이전에는 viewer 에게 scope 'health' 공개가 가능했으나, 앱 정책상 제거)
      allow read:  if signedIn() && me() == userId;
      allow write: if signedIn() && me() == userId;
    }

    // 식단 좋아요 — 식단을 볼 수 있는 사람(=owner 또는 calendar viewer)만 read.
    // 본인 좋아요만 create/delete (문서 id == 본인 uid 강제).
    match /users/{ownerUid}/meals/{mealId}/likes/{viewerUid} {
      allow read: if signedIn()
        && (me() == ownerUid || isViewerWithScope(ownerUid, 'calendar'));
      allow create, delete: if signedIn()
        && me() == viewerUid
        && (me() == ownerUid || isViewerWithScope(ownerUid, 'calendar'));
    }

    // 식단 댓글 — 식단을 볼 수 있는 사람만 read/create.
    // update 는 작성자만, delete 는 작성자 또는 식단 소유자.
    // parentCommentId (대댓글용) 필드는 선택이며 create 시 값이 오면 1단계 깊이만 허용한다.
    match /users/{ownerUid}/meals/{mealId}/comments/{cid} {
      allow read: if signedIn()
        && (me() == ownerUid || isViewerWithScope(ownerUid, 'calendar'));
      allow create: if signedIn()
        && (me() == ownerUid || isViewerWithScope(ownerUid, 'calendar'))
        && request.resource.data.authorUid == me()
        && request.resource.data.ownerUid == ownerUid
        && request.resource.data.mealId == mealId;
      allow update: if signedIn()
        && resource.data.authorUid == me()
        && request.resource.data.authorUid == resource.data.authorUid
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.mealId == resource.data.mealId
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if signedIn()
        && (resource.data.authorUid == me() || me() == ownerUid);
    }

    // 댓글 좋아요 — 식단을 볼 수 있는 사람만 read/create/delete.
    // 한 사람당 한 문서 (id == viewerUid) 로 unique.
    match /users/{ownerUid}/meals/{mealId}/comments/{cid}/likes/{viewerUid} {
      allow read: if signedIn()
        && (me() == ownerUid || isViewerWithScope(ownerUid, 'calendar'));
      allow create, delete: if signedIn()
        && me() == viewerUid
        && (me() == ownerUid || isViewerWithScope(ownerUid, 'calendar'));
    }

    // 활동 알림함 — 수신자만 read/update; create 는 본인 검증 + 서로 달력 공유 친구 관계일 때만 허용.
    match /users/{recipientUid}/activityInbox/{nid} {
      allow read, update, delete: if signedIn() && me() == recipientUid;
      allow create: if signedIn()
        && recipientUid != me()
        && request.resource.data.recipientUid == recipientUid
        && request.resource.data.actorUid == me()
        && request.resource.data.read == false
        && request.resource.data.kind is string
        && request.resource.data.actorName is string
        && request.resource.data.actorName.size() > 0
        && request.resource.data.actorName.size() <= 150
        && request.resource.data.mealOwnerUid is string
        && request.resource.data.mealId is string
        && request.resource.data.mealDate is string
        && request.resource.data.mealSlot is string
        && request.resource.data.createdAt is int
        // 식단 관련 알림은 — 수신자가 식단 소유자이면 actor 가 그 달력을 볼 수 있어야 하고,
        // 수신자가 댓글 작성자면 actor·수신자 모두 그 식단 달력을 공유받은 관계여야 한다.
        && (
          (recipientUid == request.resource.data.mealOwnerUid
            && calendarShareToward(recipientUid, me()))
          || (recipientUid != request.resource.data.mealOwnerUid
            && calendarShareToward(request.resource.data.mealOwnerUid, me())
            && calendarShareToward(request.resource.data.mealOwnerUid, recipientUid))
        )
        && (
          !('snippet' in request.resource.data)
          || (request.resource.data.snippet is string && request.resource.data.snippet.size() <= 220)
        )
        && (
          !('actorPhotoURL' in request.resource.data)
          || request.resource.data.actorPhotoURL is string
        )
        && (
          !('commentId' in request.resource.data)
          || request.resource.data.commentId is string
        );
    }

    // DM 읽음 상태 — 본인 서브컬렉션만 (catch-all 과 동일하지만 경로를 명시해 규칙 평가를 분명히 함)
    match /users/{userId}/dmReadState/{docId} {
      allow read, write: if signedIn() && me() == userId;
    }

    match /users/{userId}/{document=**} {
      allow read, write: if signedIn() && me() == userId;
    }

    // ----- 1:1 DM -----
    function dmPairOk(p) {
      return p is list
        && p.size() == 2
        && p[0] is string
        && p[1] is string
        && p[0] < p[1]
        && p[0].size() > 0
        && p[1].size() > 0;
    }
    // threadId 규약(uidA_uidB, uidA < uidB) — 부모 get() 없이 참가자 판별(메시지·스레드 read 공통)
    function dmThreadPeersFromDocId(tid) {
      return tid.split('_');
    }
    function dmMessageReadAllowed(threadId) {
      let p = dmThreadPeersFromDocId(threadId);
      return p.size() == 2
        && p[0] is string
        && p[1] is string
        && p[0].size() > 0
        && p[1].size() > 0
        && p[0] < p[1]
        && (request.auth.uid == p[0] || request.auth.uid == p[1]);
    }
    match /dmThreads/{threadId} {
      // 단일 문서 get — participantUids 가 없거나 꼬인 레거시도 문서 id 규약으로 허용(메시지 규칙과 동일).
      allow get: if request.auth != null
        && (
          (resource.data.participantUids is list && request.auth.uid in resource.data.participantUids)
          || dmMessageReadAllowed(threadId)
        );

      // 컬렉션 list 쿼리(where participantUids array-contains me)
      // — array-contains 결과는 항상 이 조건을 만족해야 하므로 is list 가 실패해 막히는 데이터가 있으면 제외하기 위해
      //   keys + in 만 요구(필드가 list 가 아니면 해당 문서는 list 평가에서 거절되어 쿼리 전체가 막힐 수 있음 — 클라이언트는 항상 배열로 저장).
      allow list: if signedIn()
        && resource.data.keys().hasAll(['participantUids'])
        && request.auth.uid in resource.data.participantUids;
      allow create: if signedIn()
        && dmPairOk(request.resource.data.participantUids)
        && threadId == request.resource.data.participantUids[0] + '_' + request.resource.data.participantUids[1]
        && me() in request.resource.data.participantUids
        && dmCalendarConnected(
          request.resource.data.participantUids[0],
          request.resource.data.participantUids[1]
        )
        && request.resource.data.lastText is string
        && request.resource.data.lastSenderUid is string
        && (request.resource.data.updatedAt is int || request.resource.data.updatedAt is float)
        && (request.resource.data.createdAt is int || request.resource.data.createdAt is float);
      // 참가자면 미리보기·메타 갱신 허용 — diff/필드 나열은 거절 원인이 되기 쉬움
      allow update: if signedIn()
        && resource.data.participantUids is list
        && me() in resource.data.participantUids;
    }

    match /dmThreads/{threadId}/messages/{mid} {
      allow read: if signedIn() && dmMessageReadAllowed(threadId);
      // create 도 read 와 동일하게 threadId(uid소_uid큰) 규약만 검사 — 부모 get() 은 거절·지연 원인이 됨
      allow create: if signedIn()
        && dmMessageReadAllowed(threadId)
        && request.resource.data.senderUid == me()
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 4000;
      allow update, delete: if false;
    }

    // ----- 공개 프로필 -----
    // create/update 는 본인만 + 데이터 무결성 검사. delete 는 검사할 request.resource
    // 가 없으므로 본인 여부만 확인 (전체 데이터 삭제 시 사용).
    match /publicProfiles/{uid} {
      allow read: if signedIn();
      allow create, update: if signedIn() && me() == uid
        && request.resource.data.uid == uid
        && request.resource.data.email == myEmail();
      allow delete: if signedIn() && me() == uid;
    }

    // ----- 링크 초대 코드 (1회용 토큰) -----
    // /friendInviteCodes/{codeId} — 발급자(fromUid)가 링크를 공유하고, 수락자가 share 를 만든다.
    match /friendInviteCodes/{codeId} {
      allow get: if signedIn();
      allow list: if signedIn() && resource.data.fromUid == me();

      // 본문 fromEmail은 앱에서 소문자 정규화되는데 JWT email 은 대소문자 혼합일 수 있어
      // 토큰과 문자열 일치를 요구하지 않는다(fromUid/me() 로 이미 본인 확인).
      function inviteFromEmailFieldOk() {
        return request.resource.data.fromEmail is string
          && request.resource.data.fromEmail.size() > 0
          && request.resource.data.fromEmail.size() <= 320;
      }
      function inviteUsedByEmailFieldOk() {
        return request.resource.data.usedByEmail is string
          && request.resource.data.usedByEmail.size() > 0
          && request.resource.data.usedByEmail.size() <= 320;
      }

      allow create: if signedIn()
        && codeId == request.resource.data.id
        && request.resource.data.fromUid == me()
        && inviteFromEmailFieldOk()
        && request.resource.data.fromName is string
        && request.resource.data.fromName.size() > 0
        && request.resource.data.fromName.size() <= 150
        && request.resource.data.requestedScope.calendar == true
        && request.resource.data.requestedScope.health != true
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt < request.resource.data.expiresAt
        // createdAt/expiresAt 은 밀리초 정수 — duration 은 Timestamp 전용이라 숫자와 더하면 규칙이 실패(거부)함.
        && request.resource.data.expiresAt
             <= request.resource.data.createdAt + 259200000;

      allow delete: if signedIn() && resource.data.fromUid == me();

      function invitePhotoUnchanged() {
        return (!('fromPhotoURL' in resource.data) && !('fromPhotoURL' in request.resource.data))
          || request.resource.data.fromPhotoURL == resource.data.fromPhotoURL;
      }

      /** expiresAt 이 숫자(ms) 또는 Timestamp 로 저장된 문서 모두 허용 (규칙에서 타입 불일치 시 전부 거절됨) */
      function inviteNotExpiredYet() {
        let exp = resource.data.expiresAt;
        return exp is timestamp ? request.time < exp : request.time.toMillis() < exp;
      }

      /** 맵 깊은 동등(==)이 필드 유무 차이로 실패하는 경우 방지 */
      function inviteScopeHealth(scope) {
        return ('health' in scope) ? scope.health : false;
      }
      function inviteRequestedScopeUnchanged() {
        let rq = request.resource.data.requestedScope;
        let rs = resource.data.requestedScope;
        return rq.calendar == rs.calendar
          && inviteScopeHealth(rq) == inviteScopeHealth(rs)
          && inviteScopeHealth(rq) != true;
      }

      allow update: if signedIn()
        && resource.data.status == 'pending'
        && inviteNotExpiredYet()
        && invitePhotoUnchanged()
        && request.resource.data.id == resource.data.id
        && request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.fromEmail == resource.data.fromEmail
        && request.resource.data.fromName == resource.data.fromName
        && inviteRequestedScopeUnchanged()
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.expiresAt == resource.data.expiresAt
        && (
          (
            request.resource.data.status == 'used'
            && me() != resource.data.fromUid
            && request.resource.data.usedByUid == me()
            && inviteUsedByEmailFieldOk()
            && (request.resource.data.usedAt is int || request.resource.data.usedAt is float)
          )
          || (
            request.resource.data.status == 'revoked'
            && me() == resource.data.fromUid
            && (request.resource.data.revokedAt is int || request.resource.data.revokedAt is float)
          )
        );
    }

    // ----- follow 신청 -----
    // 신청자(fromUid)가 수신자(toEmail/toUid)에게 보고 싶은 범위(requestedScope)를 보냄.
    // 수락은 수신자만 가능 (acceptedScope 는 수신자가 결정 후 shares 문서를 함께 만든다).
    match /followRequests/{reqId} {
      allow read: if signedIn()
        && (resource.data.fromUid == me() || resource.data.toEmail == myEmail());
      allow create: if signedIn()
        && request.resource.data.fromUid == me()
        && request.resource.data.fromEmail == myEmail()
        && request.resource.data.status == 'pending';
      allow update: if signedIn()
        && (resource.data.fromUid == me() || resource.data.toEmail == myEmail())
        && request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toEmail == resource.data.toEmail;
      allow delete: if signedIn()
        && (resource.data.fromUid == me() || resource.data.toEmail == myEmail());
    }

    // ----- 단방향 share 문서 -----
    // 수락한 사람이 owner 가 되어 본인 share 문서를 만든다.
    // viewer/owner 짝은 불변, 양쪽 모두 read/delete 가능 (인스타에서 unfollow 와 "팔로워 삭제" 둘 다 가능).
    // 없는 문서를 트랜잭션으로 get 할 때는 resource.data 가 비어 규칙만으로 거절되는 문제가 있어 존재 시에만 소유자/viewer 검사.
    //
    // 링크 초대 수락 시 "맞팔" — 역방향 문서(id: owner_viewer) 는 원래 owner 만 create 가능하므로,
    // 이미 존재하는 반대 방향 share(수락자→발급자) 가 같은 트랜잭션에 있으면 수락자가 viewer 인 역방향 문서를 create 할 수 있게 예외를 둔다.
    function mutualReverseShareCreateOk(shareSid) {
      let o = request.resource.data.ownerUid;
      let v = request.resource.data.viewerUid;
      let revId = v + '_' + o;
      return o is string
        && v is string
        && o.size() > 0
        && v.size() > 0
        && o != v
        && me() == v
        && shareSid == o + '_' + v
        && exists(/databases/$(database)/documents/shares/$(revId))
        && get(/databases/$(database)/documents/shares/$(revId)).data.ownerUid == v
        && get(/databases/$(database)/documents/shares/$(revId)).data.viewerUid == o;
    }
    match /shares/{sid} {
      allow read: if signedIn()
        && (
          !exists(/databases/$(database)/documents/shares/$(sid))
          || me() == resource.data.ownerUid
          || me() == resource.data.viewerUid
        );
      allow create: if signedIn()
        && (
          (
            me() == request.resource.data.ownerUid
            && sid == request.resource.data.ownerUid + '_' + request.resource.data.viewerUid
          )
          || mutualReverseShareCreateOk(sid)
        );
      allow update: if signedIn()
        && me() == resource.data.ownerUid
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.viewerUid == resource.data.viewerUid;
      allow delete: if signedIn()
        && (me() == resource.data.ownerUid || me() == resource.data.viewerUid);
    }

    // ----- 레거시 friendships 컬렉션 (deprecated) -----
    // 신규 코드는 더 이상 쓰지 않습니다. 기존 데이터를 정리하기 위해 read/delete 만 허용.
    match /friendships/{fid} {
      allow read:   if signedIn() && me() in resource.data.users;
      allow delete: if signedIn() && me() in resource.data.users;
    }

    // ----- 레거시 friendRequests 컬렉션 (deprecated) -----
    match /friendRequests/{reqId} {
      allow read: if signedIn()
        && (resource.data.fromUid == me() || resource.data.toEmail == myEmail());
      allow delete: if signedIn()
        && (resource.data.fromUid == me() || resource.data.toEmail == myEmail());
    }
  }
}
